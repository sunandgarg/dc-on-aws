BACKEND_USE_SUPABASE=yes
BACKEND_USE_AWS=no
SUPABASE_URL=https://your-project.supabase.co
# Used only when an incoming browser request does not carry an apikey. This is
# the publishable key; never substitute the service-role key for a user request.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
SUPABASE_SERVICE_ROLE_KEY=server-only-secret
CORS_ORIGIN=https://www.dekhocampus.in
PORT=8787
