# Public browser configuration. Set the real values in Vercel; never commit .env.local.
VITE_SUPABASE_URL=https://kozdctbbvrnyddlftmvf.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_WITH_YOUR_KEY
# Backend selection. Keep these defaults until the AWS health check and shadow
# traffic verification are complete.
VITE_USE_SUPABASE=yes
VITE_USE_AWS=no
VITE_AWS_API_URL=https://api.dekhocampus.in

# Server-only. Use the same long random value in Vercel and Supabase Edge Function secrets.
BLOG_AGENT_SECRET=replace_with_long_random_secret

# Optional. If set, Vercel Cron calls include Authorization: Bearer $CRON_SECRET.
CRON_SECRET=replace_with_long_random_secret
